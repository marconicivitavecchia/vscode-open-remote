{
  "name": "open-remote",
  "displayName": "Open Remote (Marconi)",
  "version": "1.0.0",
  "icon": "icon.png",
  "engines": { "vscode": "^1.70.0" },
  "description": "Apre il file corrente nel Simple Browser mappando il path locale all'URL del server remoto del Marconi.",
  "activationEvents": ["onCommand:open-remote.open"],
  "repository": {
    "type": "git",
    "url": "https://github.com/marconicivitavecchia/vscode-open-remote"
  },
  "contributes": {
    "commands": [{
      "command": "open-remote.open",
      "title": "Apri nel server remoto (Marconi)",
      "icon": "$(globe)"
    }],
    "menus": {
      "editor/title": [{
        "command": "open-remote.open",
        "group": "navigation"
      }]
    }
  },
  "main": "./extension.js"
}